@misc{FP24,
  title={Gigantamax Copperajah: When Cryptanalysis meets Sumsets}, 
  author={Yansong Feng and Yanbin Pan},
  year={2024},
  abstract={We introduce a new tool called Sumsets theory from Additive combination. In the coppersmith method, we only need to care about the highest term of the lattice dimension $\dim(\mathcal{L})$ and $X_1, X_2,\ldots,X_k$. In fact, this polynomial corresponds to a Hilbert function of some graded module, and the leading coefficient of this Hilbert function can be directly obtained by calculating the volume of some Newton polytopes. 

For the Automated Coppersmith proposed by Meers and Nowakowski in Asiacrypt'23, we directly eliminate the need to calculate $f^m$ when m is large enough. In fact, when f is a simple polynomial of four variables, our method can reduce it from 20 minutes dropped to less than 0.5s, which is an increase of 2000x. In addition, we gave a new angle to understand Automated Coppersmith, thus giving a proof of the $\text{Heuristic} 2 (n=1)$ in their paper.},
  selected = {false},
  abbr = {Copperajah},
  preview = {copperajah.png},
  bibtex_show={true}
}
@misc{FNP24,
  title={Combee: Provable Automated Coppersmith for Linear Equations and its Applications}, 
  author={Yansong Feng and Abderrahmane Nitaj and Yanbin Pan},
  year={2024},
  abstract={At Asiacrypt'23,  Meers and  Nowakowski proposed a new automated method called Automated Coppersmith, which automatically selects a family of polynomials to construct lattices with good properties and then finds the small roots of the given polynomial equations. However, their strategy arises a new heuristic assumption. In this paper, we give a provable vision on linear equation systems, which is widely used in cryptanalysis such as modular multivariate linear equations by Herrmann and May (Asiacrypt’08) and modular univariate linear equations by Cohn and Heninger (ANTS’12). Besides, we introduce new variables to Automated Coppersmith that can be optimized to better utilize the properties of the origin polynomial. Finally, we apply this method to analyze the Generalized Extended Implicit Factorization Problem (G-EIFP), a generalization of  the Extended Implicit Factorization Problem (EIFP), even when the shared contiguous bits are arbitrary.},
  selected = {false},
  abbr = {Combee-ifp},
  preview = {combee.png},
  bibtex_show={true}
}
@misc{CFP24,
  title={Embedding Integer Lattices as Ideals into  Polynomial Rings}, 
  author={Yihang Cheng and Yansong Feng and Yanbin Pan},
  year={2024},
  eprint={2307.12497},
  archivePrefix={arXiv},
  primaryClass={cs.CR},
  abstract={Many lattice-based crypstosystems employ ideal lattices for high efficiency. However, the additional algebraic structure of ideal lattices usually makes us worry about the security, and it is widely believed that the algebraic structure will help us solve the hard problems in ideal lattices more efficiently. In this paper, we study the additional algebraic structure of ideal lattices further and find that a given ideal lattice in a polynomial ring can be embedded as  an ideal into infinitely many different polynomial rings by the coefficient embedding. We design an algorithm to verify whether a given full-rank lattice in $\mathbb{Z}^n$ is an ideal lattice and output all the polynomial rings that the given lattice can be embedded into as an ideal with time complexity {$\mathcal{O}(n^3B(B+\log n)$}, where $n$ is the dimension of the lattice and $B$ is the upper bound of the bit length of the entries of the input lattice basis. We would like to point out that Ding and Lindner proposed an algorithm for identifying ideal lattices and outputting a single polynomial ring that the input lattice can be embedded into with time complexity $\mathcal{O}(n^5B^2)$ in 2007. However, we find a flaw in Ding and Lindner's algorithm that causes some ideal lattices can't be identified by their algorithm.},
  selected = {true},
  pdf = {https://arxiv.org/pdf/2307.12497.pdf}, 
  code = {https://github.com/fffmath/Identifying-Ideal-Lattice}, 
  abbr = {Embedding},
  bibtex_show={true}
}

@article{FNP23b,
  title = {Partial Prime Factor Exposure Attacks on Some RSA Variants},
  journal = {Theoretical Computer Science},
  pages = {114549},
  year = {2024},
  issn = {0304-3975},
  author = {Yansong Feng and Abderrahmane Nitaj and Yanbin Pan},
  abstract = {In this paper, we consider five variants of the RSA cryptosystem, where the modulus is N=pq, and the public key e and the secret key d satisfy ed−k(p2+p+1)(q2+q+1)=1 or ed−k(p2−1)(q2−1)=1. Our results show that if a certain amount of the most significant bits of p are known so that |p−p0|=Nβ with a known p0, then one can factor the RSA modulus with a better bound than low private exponent attacks. We also present the experimental results to verify our analysis.}
  abbr = {PPFE Attack},
  bibtex_show={true}
}

@inproceedings{FNP23a,
  author       = {Yansong Feng and Abderrahmane Nitaj and Yanbin Pan},
  title        = {Generalized Implicit Factorization Problem},
  booktitle    = {Selected Areas in Cryptography - 30th International Conference},
  series       = {Lecture Notes in Computer Science},
  publisher    = {Springer},
  year         = {2023},
  abstract = {The Implicit Factorization Problem (IFP) was first introduced by May and Ritzenhofen at PKC'09, which concerns the factorization of two RSA moduli {$N_1=p_1q_1$} and {$N_2=p_2q_2$}, where {$p_1$} and {$p_2$} share a certain consecutive number of least significant bits. Since its introduction, many different variants  of IFP have been considered, such as the cases where $p_1$ and $p_2$ share most significant bits or middle bits at the same positions. In this paper, we consider a more generalized case of IFP,  in which the shared consecutive bits can be located  at {\textit{any}} positions in each prime, not necessarily required to be located at the same positions as before. We propose a lattice-based algorithm to solve this problem  under specific conditions, and also provide some experimental results to verify our analysis.},
  selected = {true}, 
  pdf = {https://eprint.iacr.org/2023/1562.pdf}, 
  code = {https://github.com/fffmath/gifp}, 
  abbr = {GIFP},
  bibtex_show={true}
}

@misc{LFP22,
  title={On Rangasamy's outsourcing algorithm for solving quadratic congruence equations}, 
  author={Xiulan Li and Yansong Feng and Yanbin Pan},
  year={2022},
  eprint={2203.10751},
  archivePrefix={arXiv},
  primaryClass={cs.CR},
  abstract={Outsourcing computation is a desired approach for IoT (Internet of Things) devices to transfer their burdens of heavy computations to those nearby, resource-abundant cloud servers. Recently, Rangasamy presented a passive attack against two outsourcing algorithms proposed by Zhang et al. for solving quadratic congruence equations, which is widely used in IoT applications. Furthermore, he also proposed a modified algorithm to fix these schemes and claimed that his algorithm was correct and enabled secure and verifiable delegation of solving quadratic congruence equations in IoTs. However, we show that Rangasamy's modified algorithm has a flaw which makes it incorrect and also propose some further attacks to break the security claim, even when the flaw has been corrected.},
  selected = {false},
  pdf = {https://arxiv.org/pdf/2203.10751.pdf}, 
  abbr = {Rangasamy},
  bibtex_show={true}
}